{
  "name": "bootstrap-custom-vue-ui",
  "version": "2.3.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/assets/scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./directives/tooltip": {
      "types": "./dist/directives/tooltip.d.ts",
      "import": "./dist/directives/tooltip.js",
      "require": "./dist/directives/tooltip.cjs"
    },
    "./directives/popover": {
      "types": "./dist/directives/popover.d.ts",
      "import": "./dist/directives/popover.js",
      "require": "./dist/directives/popover.cjs"
    },
    "./src/assets/scss/*": "./src/assets/scss/*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "bootstrap": {
      "optional": true
    },
    "@popperjs/core": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "bootstrap": "^5.3.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "pug": "^3.0.3",
    "sass": "^1.79.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.24",
    "vue-tsc": "^3.2.7"
  }
}
