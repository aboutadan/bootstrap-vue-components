{
  "name": "bootstrap-custom-vue-ui",
  "version": "2.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/assets/scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./directives/tooltip": {
      "types": "./dist/directives/tooltip.d.ts",
      "import": "./dist/directives/tooltip.js",
      "require": "./dist/directives/tooltip.cjs"
    },
    "./directives/popover": {
      "types": "./dist/directives/popover.d.ts",
      "import": "./dist/directives/popover.js",
      "require": "./dist/directives/popover.cjs"
    },
    "./src/assets/scss/*": "./src/assets/scss/*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "bootstrap": {
      "optional": true
    },
    "@popperjs/core": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "bootstrap": "^5.3.8",
    "pug": "^3.0.3",
    "sass": "^1.79.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.24"
  }
}
